# ─── Discord Bot ───
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_dev_guild_id_here

# ─── Database ───
MONGODB_URI=mongodb://localhost:27017/tsber-leaderboard

# ─── Channel IDs ───
# Leaderboard channels (Top 10, Top 20, Top 30)
LEADERBOARD_CHANNEL_1_ID=
LEADERBOARD_CHANNEL_2_ID=
LEADERBOARD_CHANNEL_3_ID=
# LB Info channel — where the [Create]/[Challenge] ticket panel lives
TICKETS_CHANNEL_ID=
TICKETS_CATEGORY_ID=
LOA_CHANNEL_ID=

# ─── Role IDs ───
REFEREES_ROLE_ID=
STAFF_ROLE_IDS=

# ─── Notes ───
# Staff = anyone with Administrator permission (automatically detected)
# Set STAFF_ROLE_IDS only if you want additional non-admin roles to have staff access
